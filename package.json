{
  "name": "april-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "General-purpose TypeScript agent runtime with ReAct loop, tool execution, and local persistence.",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist .vitest coverage",
    "demo:cli": "npm run build && node --env-file=.env.local dist/src/cli/minimal-cli.js",
    "demo:min": "npm run build && node --env-file=.env.local examples/minimal-run.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
